# ─── 사이트 ────────────────────────────────────────────────────────
# ⚠️ CRITICAL: 이 값은 Google Search Console 속성 도메인과 정확히 일치해야 함
# 불일치 시 sitemap.xml의 모든 URL이 다른 도메인으로 생성되어 GSC가 "가져올 수 없음" 보고
# 예) GSC 속성: https://food-ai.utilverse.info → 여기도 동일하게
NEXT_PUBLIC_SITE_URL=https://food-ai.utilverse.info

# ─── AdSense ───────────────────────────────────────────────────────
# Publisher ID — AdSense 가입 후 발급 (ca-pub-로 시작)
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXX
# 슬롯 ID — AdSense 승인 후 광고 단위 생성하여 입력 (코드 변경 없이 활성화)
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
NEXT_PUBLIC_ADSENSE_SLOT_IN_ARTICLE=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# ─── Analytics & Verification ──────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# GSC 사이트 소유 확인 코드 (메타 태그 방식)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=google-site-verification-code

# ─── Gemini ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here
GEMINI_API_KEY_3=your_third_gemini_api_key_here
GEMINI_API_KEY_4=your_fourth_gemini_api_key_here

# ─── 외부 API ──────────────────────────────────────────────────────
GPT_API_KEY=your_openai_api_key_here
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
GOOGLE_CSE_API_KEY=your_google_custom_search_api_key
GOOGLE_CSE_ID=your_programmable_search_engine_id
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
